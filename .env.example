# Copy this file to .env and fill in your actual values.
# .env is gitignored and must never be committed.

# Anthropic API key — required for the LLM enrichment stage.
# Obtain one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# GitHub personal access token — optional but strongly recommended.
# Without it the GitHub API rate limit is 60 requests/hour (vs 5000 authenticated).
# Create one at https://github.com/settings/tokens (no scopes needed for public repos).
GITHUB_TOKEN=your-github-token-here
